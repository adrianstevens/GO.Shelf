# Server port (default: 3000)
PORT=3000

# Public URL of your server.
# Used to display the correct address after login.
# Change this if accessing from other machines on your network.
HOST=http://localhost:3000

# Where downloaded installers, DLC, and extras are saved.
# Docker: this is the path inside the container — mount your drive to /downloads.
# Direct install: set to an absolute path on your system.
DOWNLOAD_DIR=/downloads

# Optional: custom path for the SQLite database.
# Defaults to ./data/gog-shelf.db
# DB_PATH=/app/data/gog-shelf.db

# Optional: HTTP basic auth to protect the UI.
# Format: username:password
# Recommended if the app is accessible beyond localhost.
# BASIC_AUTH=admin:changeme
